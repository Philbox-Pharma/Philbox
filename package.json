{
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "client/src/**/*.{js,jsx}": [
      "npm --prefix client exec eslint -- --fix",
      "npm --prefix client exec prettier -- --write"
    ],
    "server/src/**/*.js": [
      "npm --prefix server exec eslint -- --fix",
      "npm --prefix server exec prettier -- --write"
    ]
  }
}
